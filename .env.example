OCI_COMPANION_SSL_CERT_FILE=/app/certs/localhost-cert.pem
OCI_COMPANION_SSL_KEY_FILE=/app/certs/localhost-key.pem

# Optional OCI IAM settings
# OCI_IAM_DOMAIN_URL=https://<your-identity-domain>
# OCI_IAM_CLIENT_ID=<client-id>
# OCI_IAM_CLIENT_SECRET=<client-secret>
# OCI_IAM_REDIRECT_URI=https://localhost:8080/auth/callback
# OCI_IAM_SCOPES=openid profile email
# OCI_COMPANION_COOKIE_SECURE=true

# Disable OCI IAM authentication for local/container testing.
# OCI_COMPANION_NOAUTH=false

# UI testing mode: serve the existing DocumentRoot/data.json without querying OCI.
# OCI_COMPANION_UI_DEBUG=false
